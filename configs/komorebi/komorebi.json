{
  "$schema": "https://raw.githubusercontent.com/LGUG2Z/komorebi/v0.1.39/schema.json",
  "window_hiding_behaviour": "Cloak",
  "cross_monitor_move_behaviour": "Insert",
  "cross_boundary_behaviour": "Monitor",
  "default_workspace_padding": 14,
  "default_container_padding": 2,
  "mouse_follows_focus": true,
  "resize_delta": 50,
  "floating_window_aspect_ratio": "Widescreen",
  "stackbar": {
    "mode": "Never"
  },
  "animation": {
    "enabled": true,
    "duration": 80,
    "fps": 60,
    "style": "Linear"
  },
  "border": true,
  "border_implementation": "Komorebi",
  "border_width": 3,
  "border_offset": -1,
  "border_style": "Rounded",
  "border_colours": {
    "single": "#33ccff",
    "stack": "#00ff99",
    "monocle": "#33ccff",
    "unfocused": "#595959"
  },
  "monitors": [
    {
      "workspaces": [
        {
          "name": "1",
          "layout": "BSP"
        },
        {
          "name": "2",
          "layout": "BSP"
        },
        {
          "name": "3",
          "layout": "BSP"
        },
        {
          "name": "4",
          "layout": "BSP"
        },
        {
          "name": "5",
          "layout": "BSP"
        },
        {
          "name": "6",
          "layout": "BSP"
        },
        {
          "name": "7",
          "layout": "BSP"
        },
        {
          "name": "8",
          "layout": "BSP"
        },
        {
          "name": "9",
          "layout": "BSP"
        },
        {
          "name": "10",
          "layout": "BSP"
        }
      ]
    }
  ]
}
